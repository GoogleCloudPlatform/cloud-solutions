############ GCP ENVIRONMENT CONFIGURATIONS ############
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>
GOOGLE_CLOUD_LOCATION=global
MODELS_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_BUCKET_ARTIFACTS=<your-project-id>-artifacts

############ DEMO BUCKET ############
DEMO_BUCKET=

############ LLM MODELS FOR AGENTS ############
LLM_GEMINI_MODEL_MARKETING_ANALYST=gemini-3.1-pro-preview
LLM_GEMINI_MODEL_ADGEN_ROOT=gemini-3.1-pro-preview
LLM_GEMINI_MODEL_EVALUATION=gemini-3.1-pro-preview
MODEL_NAME=gemini-3.1-pro-preview

############ MODELS FOR GENMEDIA ############
IMAGE_GENERATION_MODEL=gemini-3.1-flash-image-preview
IMAGE_MODEL_NAME=gemini-3-pro-image-preview
VIDEO_GENERATION_MODEL=veo-3.1-generate-001
AUDIO_TTS_GENERATION_MODEL=gemini-2.5-pro-tts
AUDIO_TTS_VOICE_NAME=Charon
AUDIO_LYRIA_GENERATION_MODEL=lyria-002

############ CONFIGURATIONS FOR GENMEDIA ############
IMAGE_DEFAULT_ASPECT_RATIO=9:16
VIDEO_DEFAULT_ASPECT_RATIO=9:16
VIDEO_DEFAULT_RESOLUTION=1080p
VIDEO_DEFAULT_DURATION=4
IMAGE_GENERATION_TENACITY_ATTEMPTS=3
IMAGE_GENERATION_EVAL_REATTEMPTS=0
IMAGE_GENERATION_CONCURRENCY_LIMIT=5
IMAGE_GENERATION_RETRY_DELAY_SECONDS=1
VIDEO_GENERATION_TENACITY_ATTEMPTS=3
VIDEO_GENERATION_EVAL_REATTEMPTS=0
VIDEO_GENERATION_CONCURRENCY_LIMIT=3
VIDEO_GENERATION_RETRY_DELAY_SECONDS=1
VIDEO_GENERATION_STATUS_POLL_SECONDS=5
AUDIO_GENERATION_TENACITY_ATTEMPTS=3
SLEEP_SECONDS_GEN_IMAGE=0.0
SLEEP_SECONDS_GEN_VIDEO=0.0
RENDER_IMAGES_INLINE=true
RENDER_VIDEOS_INLINE=true

############ AGENT STATE/SESSION ############
DEMO_COMPANY_NAME=GenMedia
AGENT_VERSION=5.20260410.1
MARKETING_ANALYST_DATASTORE_CLOUD_BUCKET=<your-project-id>-analyst-bucket
CAMPAIGNS_CONFIG_URL=
SELECTED_CAMPAIGN_FILE_NAME=selected_campaign_name
SELECTED_ASSET_SHEET_FILE_NAME=selected_asset_sheet_name
SESSION_STATE_FILE_NAME=session_state

############ BIGQUERY ############
BQ_DATASET=retail_analytics
WITH_MOCKED_DATA=false

############ SAFETY NETS ############
BACKUP_CATALOG_IMAGE_URL=
BACKUP_LOGO_IMAGE_URL=

############ GOOGLE ADS (optional — only needed for publishing) ############
DEVELOPER_TOKEN=<your-google-ads-developer-token>
PROJECT_ID=<your-gcp-project-id>
GOOGLE_ADS_ACCOUNT_ID=<your-10-digit-account-id>
GOOGLE_ADS_CUSTOMER_ID=<your-10-digit-customer-id>
GOOGLE_ADS_IS_MCC=true

############ NO NEED TO CHANGE ############
GOOGLE_GENAI_USE_VERTEXAI=TRUE
