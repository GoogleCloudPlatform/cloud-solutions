GOOGLE_CLOUD_LOCATION=us-central1
# Google Cloud Project Credentials
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_GENAI_USE_VERTEXAI=True

# Staging GCS Bucket (Required for Vertex AI Agent Engine deployment)
GOOGLE_CLOUD_STORAGE_BUCKET=gs://your-staging-bucket-name

# BigQuery Datasets and Tables
# NOTE: Use underscores (_) instead of hyphens (-) in ASSET_DATASET to prevent standard SQL query syntax errors.
ASSET_DATASET=mfg_assets
ASSET_TABLE=vertex_high_pressure_coolant_pump
HISTORICAL_FAILURES_TABLE=historical_failures
